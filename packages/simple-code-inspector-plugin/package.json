{
  "name": "simple-code-inspector-plugin",
  "version": "1.6.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "typings": "./types/index.d.ts",
  "repository": "git@github.com:lakphy/simple-code-inspector.git",
  "author": "lakphy",
  "license": "MIT",
  "scripts": {
    "clear": "rimraf ./dist && rimraf ./types",
    "build": "pnpm clear && tsc && vite build",
    "pub": "pnpm publish",
    "pub:beta": "pnpm publish --tag beta"
  },
  "files": [
    "dist",
    "types"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dist/*": {
      "import": {
        "default": "./dist/*"
      },
      "require": {
        "default": "./dist/*"
      }
    }
  },
  "homepage": "https://inspector.fe-dev.cn/en",
  "description": "Click the dom on the page, it will copy the source code location of the dom to your clipboard.",
  "keywords": [
    "webpack",
    "vite",
    "plugin",
    "vue",
    "clipboard",
    "inspector",
    "inspect"
  ],
  "bugs": {
    "url": "https://github.com/lakphy/simple-code-inspector/issues"
  },
  "dependencies": {
    "chalk": "4.1.1",
    "@simple-code-inspector/core": "workspace:*",
    "@simple-code-inspector/vite": "workspace:*",
    "@simple-code-inspector/webpack": "workspace:*",
    "@simple-code-inspector/esbuild": "workspace:*",
    "@simple-code-inspector/turbopack": "workspace:*",
    "@simple-code-inspector/mako": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^16.0.1",
    "typescript": "^4.9.3",
    "vite": "^4.1.0"
  }
}